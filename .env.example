# ── Anthropic (existing — required for mock interview + StoryBank extraction)
ANTHROPIC_API_KEY=sk-ant-xxx

# ── Turso (required for StoryBank database)
TURSO_DATABASE_URL=libsql://[db-name]-[org].turso.io
TURSO_AUTH_TOKEN=[your-turso-auth-token]

# ── Auth.js (required for StoryBank authentication)
NEXTAUTH_SECRET=[run: openssl rand -base64 32]
NEXTAUTH_URL=http://localhost:3000   # production URL in Vercel env vars

# ── Auth.js email provider (Resend — required for magic link emails)
AUTH_RESEND_KEY=[your-resend-api-key]   # from resend.com dashboard

# ── Upstash Vector (required for job spec matching / Thread 6+)
UPSTASH_VECTOR_REST_URL=[your-upstash-vector-rest-url]
UPSTASH_VECTOR_REST_TOKEN=[your-upstash-vector-rest-token]

# ── OpenAI (required for embedding generation / Thread 6+)
OPENAI_API_KEY=[your-openai-api-key]

# ── Field-level encryption (optional — plaintext stored if absent)
# AES-256-GCM encryption for transcript and example sensitive fields.
# If unset, AUTH_SECRET is used as a fallback key (still encrypted).
# Generate a strong key with: openssl rand -base64 32
ENCRYPTION_KEY=[run: openssl rand -base64 32]

# ── CipherStash (not used — CipherStash does not support libSQL/SQLite)
# Evaluated during Thread 3 build. CipherStash targets PostgreSQL only.
# Encryption handled by AES-256-GCM via Node.js built-in crypto instead.
