# ── Anthropic (existing — required for mock interview + StoryBank extraction)
ANTHROPIC_API_KEY=sk-ant-xxx

# ── Turso (required for StoryBank database)
TURSO_DATABASE_URL=libsql://[db-name]-[org].turso.io
TURSO_AUTH_TOKEN=[your-turso-auth-token]

# ── Auth.js (required for StoryBank authentication)
# AUTH_SECRET replaces NEXTAUTH_SECRET in Auth.js v5
AUTH_SECRET=[run: openssl rand -base64 32]
NEXTAUTH_URL=http://localhost:3000   # production URL in Vercel env vars

# ── Google OAuth (required for sign-in)
GOOGLE_CLIENT_ID=[your-google-client-id]
GOOGLE_CLIENT_SECRET=[your-google-client-secret]

# ── Upstash Vector (required for job spec matching / Thread 6+)
UPSTASH_VECTOR_REST_URL=[your-upstash-vector-rest-url]
UPSTASH_VECTOR_REST_TOKEN=[your-upstash-vector-rest-token]

# ── OpenAI (required for embedding generation / Thread 6+)
OPENAI_API_KEY=[your-openai-api-key]

# ── Field-level encryption (optional — plaintext stored if absent)
# AES-256-GCM encryption for transcript and example sensitive fields.
# Must be a 32-byte random hex string — NOT a passphrase. If unset, encryption
# is disabled and data is stored as plaintext.
# Generate a strong key with: openssl rand -hex 32
ENCRYPTION_KEY=[run: openssl rand -hex 32]

# ── Admin API token (required for admin endpoints)
ADMIN_TOKEN=[run: openssl rand -hex 32]
